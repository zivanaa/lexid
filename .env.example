# ---- LLM providers (ALL FREE TIERS — see docs/deployment.md for limits) ----
# Fill at least ONE. Retrieval-only work (most of Phase 1) needs NONE.
GEMINI_API_KEY=            # aistudio.google.com — generation LLM (primary)
GROQ_API_KEY=              # console.groq.com — judge LLM (must differ from generator)
OPENROUTER_API_KEY=        # openrouter.ai — fallback free models

# ---- Local components (free, no keys) ----
QDRANT_PATH=./data/qdrant_local     # embedded local mode; no Docker required
EMBEDDING_MODEL=BAAI/bge-m3         # UNVERIFIED: confirm current best on MTEB before Phase 1 experiments
EMBEDDING_DEVICE=cpu                # cpu is fine for this corpus size (slow but $0)
LOG_LEVEL=INFO
